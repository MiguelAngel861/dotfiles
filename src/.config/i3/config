######################################
## ------ i3WM Configuration ------ ##
######################################

font pango:monospace 14
set $mod Mod4
set $alt Mod1
set $resize ~/.config/i3/scripts/resize-window.py
set $resize_mark __resize_target

# ------------------- #
# ---- Workspace ---- #
# ------------------- #

# --- System Process

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork

# --- Startup apps

exec --no-startup-id nitrogen --restore
exec_always --no-startup-id pkill picom; sleep 0.2; picom --no-use-damage
exec_always --no-startup-id ~/.config/polybar/launch.sh
exec_always --no-startup-id autotiling
exec --no-startup-id flameshot

# Workspaces names
set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Drag Windows
tiling_drag modifier titlebar
floating_modifier $mod

# Windows Configuration
for_window [class="^.*"] border pixel 4

gaps inner 12
gaps outer 8


# Centrar ventanas cuando pasan a modo floating

# General: Floating Windows Rules
for_window [class="kitty" title="wiremix"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 80 $resize_mark"
for_window [class="kitty" title="impala"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 80 $resize_mark"
for_window [class="kitty" title="bluetui"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 80 $resize_mark"
for_window [class="system-config-printer"] floating enable
for_window [title="Extract"] floating enable, move position center
for_window [class="mpv"] floating enable
for_window [class="Nsxiv"] floating enable

# PCSX2: Floating Windows Rules
for_window [class="pcsx2-qt" title="PCSX2 Settings"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 70 $resize_mark"
for_window [class="pcsx2-qt" title="SCES.*"] floating  enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 70 $resize_mark"
for_window [class="pcsx2-qt" title="SLES.*"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 70 $resize_mark"
for_window [class="pcsx2-qt" title="SLUS.*"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 50 70 $resize_mark"
for_window [class="pcsx2-qt" title="PCSX2 Controller Settings"] floating enable, mark --replace $resize_mark, exec --no-startup-id "$resize 70 65 $resize_mark"

# Steam: Floating Windows Rules
for_window [class=".*steam.*" title="Steam Settings"] floating enable, move position center 
for_window [class=".*steam.*" title="Friends List"] floating enable, move position center
for_window [class=".*steam.*" title="Special Offers"] floating enable, move position center
for_window [class=".*steam.*" title="Game Servers"] floating enable, move position center
for_window [class=".*steam.*" title="Players"] floating enable, move position center
for_window [class=".*steam.*" title="Add Non-Steam Game"] floating enable, move position center
for_window [class=".*steam.*" title="System Report"] floating enable, move position center
for_window [class=".*steam.*" title="Steam Runtime System Information"] floating enable, move position center

# --------------------- #
# ---- Keybindings ---- #
# --------------------- #

# --- System

# Reload / Lock / Exit
bindsym $mod+Shift+e exec "i3-nagbar -t warning -m 'You pressed the exit shortcut. Do you really want to exit i3? This will end your X session.' -B 'Yes, exit i3' 'i3-msg exit'"
bindsym $mod+Shift+c reload
bindsym $mod+Shift+r restart

# Microphone Configuration
bindsym XF86AudioMicMute exec --no-startup-id ~/.config/i3/scripts/micmute-toggle.sh

# Audio Configuration
bindsym XF86AudioRaiseVolume exec --no-startup-id ~/.config/i3/scripts/volume-control.sh up
bindsym XF86AudioLowerVolume exec --no-startup-id ~/.config/i3/scripts/volume-control.sh down
bindsym XF86AudioMute exec --no-startup-id ~/.config/i3/scripts/audiomute-toggle.sh toggle


# Brightness Configuration
bindsym XF86MonBrightnessUp exec --no-startup-id ~/.config/i3/scripts/brightness-control.sh up
bindsym XF86MonBrightnessDown exec --no-startup-id ~/.config/i3/scripts/brightness-control.sh down

# Screenshot Tools
bindsym Print exec --no-startup-id flameshot gui
bindsym $mod+Print exec --no-startup-id flameshot full --clipboard

# --- Windows

# move focused container to workspace
bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10

# switch to workspace
bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

# Move Focused Window
bindsym $mod+Shift+Right move right
bindsym $mod+Shift+Left move left
bindsym $mod+Shift+Down move down
bindsym $mod+Shift+Up move up

# Change of Focused Window
bindsym $mod+Right focus right
bindsym $mod+Left focus left
bindsym $mod+Down focus down
bindsym $mod+Up focus up

# Windows Mode
bindsym $mod+Shift+space floating toggle, move position center
bindsym $mod+space focus mode_toggle 
bindsym $mod+f fullscreen toggle

# kill focused windows
bindsym $mod+q kill

# resize windows
bindsym $mod+r mode "resize"
mode "resize" {
	# Arrow keys
	bindsym Left resize shrink width 5 px or 5 ppt
	bindsym Right resize grow width 5 px or 5 ppt
	bindsym Down resize grow height 5 px or 5 ppt
	bindsym Up resize shrink height 5 px or 5 ppt

	# Exit resize mode
	bindsym Return mode "default"
	bindsym Escape mode "default"
	bindsym $mod+r mode "default"
}

# Focus Options
bindsym $mod+a focus parent
# bindsym $mod+d focus child

# --- Programs
bindsym $alt+o exec md.obsidian.Obsidian
bindsym $alt+c exec code
bindsym $alt+Return exec kitty
bindsym $alt+z exec app.zen_browser.zen
bindsym $alt+e exec nemo

# Apps Menu
bindsym $alt+space exec "rofi -show drun -theme ~/.config/rofi/themes/warm-minimal.rasi"
#bindsym $alt+space exec "rofi -show drun"

# ---------------- #
# ---- Colors ---- #
# ---------------- #

# ==================== COLORES MINIMALISTAS ====================

# ==================== ESQUEMA CÁLIDO MINIMALISTA ====================

set $bg         #1f1a17     
set $bg2        #2c2520     
set $fg         #f5f0e8     
set $accent     #ffbf00     
set $accent2    #ffb347     
set $urgent     #ff6b4a     
set $inactive   #555555     

# class                 border          background      text            indicator       child_border
client.focused          $accent         $bg             $fg             $accent2        $accent
client.focused_inactive $bg2            $bg2            $fg             $inactive       $bg2
client.unfocused        $bg2            $bg2            #888888         $inactive       $bg2
client.urgent           $urgent         $urgent         $fg             $urgent         $urgent
client.placeholder      $bg             $bg             $fg             $bg             $bg
client.background       $bg

set $gray_dark     #777777


